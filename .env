# JHU Canvas Study Agent — Playwright version
# Copy to .env and fill in your values. Never commit .env to Git.

# Where to save downloaded materials
# Tip: point this directly at your Obsidian vault folder
# Example: /Users/mac/Documents/Obsidian/JHU/materials
STUDY_DIR=./study_materials

# Where to store your browser session (keeps you logged in between runs)
SESSION_FILE=./canvas_session.json

# Opera browser path on macOS (default — no need to change unless Opera is missing)
OPERA_PATH=/Applications/Opera.app/Contents/MacOS/Opera
